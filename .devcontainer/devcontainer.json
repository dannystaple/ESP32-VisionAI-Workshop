{
  "name": "ESP-IDF v5.4.1",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Give the container access to USB serial adapters for flashing.
  // On Linux the host devices are typically /dev/ttyUSB0 or /dev/ttyACM0.
  // --privileged is the simplest approach for embedded dev; scope it down
  // to specific devices once you know which node your board lands on.
  "runArgs": [
    "--privileged",
    "--device=/dev/ttyUSB0:/dev/ttyUSB0",
    "--device=/dev/ttyACM0:/dev/ttyACM0"
  ],

  "remoteEnv": {
    "IDF_PATH": "/opt/esp/idf",
    "IDF_TOOLS_PATH": "/opt/esp"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "idf.espIdfPath": "/opt/esp/idf",
        "idf.toolsPath": "/opt/esp",
        "idf.customExtraPaths": "",
        "idf.pythonBinPath": "/opt/esp/python_env/idf5.4_py3.11_env/bin/python",
        "C_Cpp.default.compilerPath": "/opt/esp/tools/xtensa-esp-elf/esp-13.2.0_20240530/xtensa-esp-elf/bin/xtensa-esp32s3-elf-gcc",
        "C_Cpp.default.includePath": [
          "${workspaceFolder}/**",
          "/opt/esp/idf/components/**"
        ],
        "C_Cpp.default.defines": [
          "CONFIG_IDF_TARGET_ESP32S3"
        ]
      },
      "extensions": [
        "espressif.esp-idf-extension",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake"
      ]
    }
  },

  "postCreateCommand": "bash /opt/esp/idf/install.sh esp32s3 && echo 'source /opt/esp/idf/export.sh' >> ~/.bashrc",

  "remoteUser": "root"
}
